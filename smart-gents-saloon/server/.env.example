# ─── Server ───────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Only override locally.
PORT=3001

# The deployed Vercel frontend URL — used for CORS and email CTA links.
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local: postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public
# Railway: copy the DATABASE_URL from the PostgreSQL plugin's "Connect" tab.
#          It already includes sslmode=require for production.
DATABASE_URL="postgresql://USER:emon@2026@HOST:5432/DATABASE?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets with: openssl rand -hex 32
# Use DIFFERENT values for JWT_SECRET and JWT_REFRESH_SECRET.
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-different-from-jwt-secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Found in your Cloudinary dashboard → Settings → Access Keys.
CLOUDINARY_NAME=dp2icqobi
CLOUDINARY_KEY=812628847237935
CLOUDINARY_SECRET=gVRarZ5ghtpYgjDnaE6w3TyAWIU

# ─── SMTP ─────────────────────────────────────────────────────────────────────
# Gmail example: use an App Password, not your account password.
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mdemon.aiub@gmail.com
SMTP_PASS=xwvjInclnhsuybzi 
SMTP_FROM="Smart Gents Saloon <noreply@smartgentssaloon.com>"

# Email address that receives new booking notifications.
ADMIN_EMAIL=admin@smartgentssaloon.com
