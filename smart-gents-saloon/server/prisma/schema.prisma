generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
}

enum AppointmentStatus {
  PENDING
  APPROVED
  CANCELLED
  COMPLETED
}

enum ServiceCategory {
  HAIRCUT
  BEARD_TRIM
  HAIR_COLORING
  FACIAL
  HAIR_TREATMENT
  SPA
  GROOM_PACKAGE
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// Admin and staff users — customers book as guests (no account required)
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  role         Role          @default(STAFF)
  /// Hashed refresh token; null when the user is logged out
  refreshToken String?
  isActive     Boolean       @default(true)
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("users")
}

/// Grooming service offered by the salon
model Service {
  id           String          @id @default(cuid())
  title        String
  description  String          @db.Text
  price        Float
  /// Duration in minutes
  duration     Int
  image        String?
  /// Cloudinary public ID for the service image
  publicId     String?
  category     ServiceCategory
  isActive     Boolean         @default(true)
  /// Controls display order on the frontend
  sortOrder    Int             @default(0)
  appointments Appointment[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("services")
}

/// Barber / stylist profile
model Barber {
  id           String        @id @default(cuid())
  name         String
  specialty    String
  /// Years of professional experience
  experience   Int
  bio          String?       @db.Text
  image        String?
  /// Cloudinary public ID for the barber photo
  publicId     String?
  instagram    String?
  facebook     String?
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([isActive])
  @@map("barbers")
}

/// Customer booking for a service with a specific barber
model Appointment {
  id            String            @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String
  date          DateTime          @db.Date
  /// e.g. "10:00", "14:30"
  time          String
  notes         String?           @db.Text
  /// Snapshot of the service price at the time of booking
  price         Float
  status        AppointmentStatus @default(PENDING)

  service   Service @relation(fields: [serviceId], references: [id])
  serviceId String

  barber   Barber @relation(fields: [barberId], references: [id])
  barberId String

  /// Optional link to a registered staff/admin User (for admin-created appointments)
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  testimonial Testimonial?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([date])
  @@index([serviceId])
  @@index([barberId])
  @@index([userId])
  @@map("appointments")
}

/// Salon work photos for the gallery page
model Gallery {
  id        String   @id @default(cuid())
  url       String
  /// Cloudinary public ID — required for programmatic deletion
  publicId  String
  caption   String?
  /// Free-text category e.g. "haircut", "beard", "styling"
  category  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("gallery")
}

/// Customer review / testimonial (optionally tied to a completed appointment)
model Testimonial {
  id         String   @id @default(cuid())
  name       String
  /// Star rating 1–5
  rating     Int
  comment    String   @db.Text
  avatar     String?
  isActive   Boolean  @default(true)
  /// Pin top testimonials on the homepage
  isFeatured Boolean  @default(false)

  /// One testimonial per appointment at most
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId String?      @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([isFeatured])
  @@map("testimonials")
}
